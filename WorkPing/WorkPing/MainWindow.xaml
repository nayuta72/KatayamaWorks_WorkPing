<Window
    x:Class="WorkPing.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WorkPing"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="WorkPing 2.00">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <!-- カスタムタイトルバー領域 -->
            <RowDefinition Height="48" />
            <!-- コンテンツ領域 -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============================= -->
        <!-- カスタムタイトルバー           -->
        <!-- ============================= -->
        <!-- このGridがドラッグ可能なタイトルバーになる。
             interactive なコントロール（コンボボックス）は
             InputNonClientPointerSource でクリック可能領域として登録する -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <!-- アプリアイコン + タイトル（左側） -->
                <ColumnDefinition Width="Auto" />
                <!-- スペーサー -->
                <ColumnDefinition Width="*" />
                <!-- 接続状態アイコン -->
                <ColumnDefinition Width="Auto" />
                <!-- ログファイル切り替えコンボボックス -->
                <ColumnDefinition Width="Auto" />
                <!-- ログ一覧ボタン（SplitButton） -->
                <ColumnDefinition Width="Auto" />
                <!-- ウィンドウボタン（最小化・最大化・閉じる）の余白 -->
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <!-- アプリタイトル -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="12,0,0,0">
                <TextBlock Text="WorkPing"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0" />
            </StackPanel>

            <!-- ファイルアクセス不可インジケーター（アクセスできないときのみ表示） -->
            <StackPanel x:Name="AccessWarningPanel"
                        Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        ToolTipService.ToolTip="ログファイルにアクセスできません">
                <FontIcon Glyph="&#xE814;"
                          Foreground="OrangeRed"
                          FontSize="16" />
            </StackPanel>

            <!-- ログファイル切り替えコンボボックス -->
            <!-- 部署を兼務している人がログ書き込み先を切り替えるためのコンボボックス -->
            <ComboBox x:Name="LogFileComboBox"
                      Grid.Column="3"
                      VerticalAlignment="Center"
                      MinWidth="160"
                      Margin="0,0,8,0"
                      PlaceholderText="ログファイルを選択"
                      SelectionChanged="LogFileComboBox_SelectionChanged" />

            <!-- 勤怠ログ一覧ボタン（SplitButton）
                 左クリック → モードレスウィンドウを開く
                 ドロップダウン → 表示期間（Today / Week / Month / All）を切り替える -->
            <SplitButton x:Name="LogViewerSplitButton"
                         Grid.Column="4"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"
                         Click="LogViewerSplitButton_Click"
                         ToolTipService.ToolTip="勤怠ログ一覧を開く">
                <SplitButton.Content>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE9F9;" FontSize="13" />
                        <TextBlock x:Name="LogViewerRangeLabel" Text="Today" />
                    </StackPanel>
                </SplitButton.Content>
                <SplitButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Today" Tag="Today" Click="LogViewerRange_Click" />
                        <MenuFlyoutItem Text="Week"  Tag="Week"  Click="LogViewerRange_Click" />
                        <MenuFlyoutItem Text="Month" Tag="Month" Click="LogViewerRange_Click" />
                        <MenuFlyoutItem Text="All"   Tag="All"   Click="LogViewerRange_Click" />
                    </MenuFlyout>
                </SplitButton.Flyout>
            </SplitButton>
        </Grid>

        <!-- ============================= -->
        <!-- メインコンテンツ：NavigationView -->
        <!-- ============================= -->
        <NavigationView IsPaneOpen="False" IsPaneToggleButtonVisible="False"
            x:Name="MainNavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionFollowsFocus="Disabled"
            ItemInvoked="MainNavView_ItemInvoked">

            <NavigationView.MenuItems>
                <!-- 1ページ目：出退勤通知 -->
                <NavigationViewItem
                    x:Name="AttendanceLogNavItem"
                    Content="出退勤通知"
                    Tag="AttendanceLog">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF2A3;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- 2ページ目：ショートカット -->
                <NavigationViewItem
                    x:Name="ShortcutNavItem"
                    Content="ショートカット"
                    Tag="Shortcut">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- 3ページ目：設定 -->
                <NavigationViewItem
                    x:Name="AccountSettingsNavItem"
                    Content="設定"
                    Tag="AccountSettings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- ページコンテンツを表示するFrame -->
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
