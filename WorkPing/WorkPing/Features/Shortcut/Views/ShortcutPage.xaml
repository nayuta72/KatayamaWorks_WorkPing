<Page
    x:Class="WorkPing.Features.Shortcut.Views.ShortcutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WorkPing.Features.Shortcut.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <!--
            ShortcutPanel は縦 StackPanel。
            コードビハインドでショートカットボタン（横3列の行 StackPanel）が
            「追加」ボタンの前に順次挿入される。
            「追加」ボタン自体は XAML でここに固定配置し、常に最後尾に表示される。
        -->
        <StackPanel x:Name="ShortcutPanel"
                    Orientation="Vertical"
                    HorizontalAlignment="Left">

            <!-- ========================================= -->
            <!-- 追加ボタン（常に最後尾に固定） -->
            <!-- コードビハインドはこのボタンを残しながら、 -->
            <!-- その前にショートカットボタンを挿入する。   -->
            <!-- ========================================= -->
            <Button Margin="4"
                    Click="AddShortcutButton_Click"
                    Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock Text="追加" />
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Page>
