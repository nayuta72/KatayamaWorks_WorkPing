<Page
    x:Class="WorkPing.Features.AccountSettings.Views.AccountSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WorkPing.Features.AccountSettings.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="700">

            <!-- ============================= -->
            <!-- ユーザー情報                   -->
            <!-- ============================= -->
            <TextBlock Text="ユーザー情報"
                       Style="{StaticResource SubtitleTextBlockStyle}" />

            <!-- 部署名・姓・名・ユーザーID（横並び） -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="部署名" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox Text="{x:Bind ViewModel.DepartmentName.Value, Mode=TwoWay}"
              PlaceholderText="例：企画部" />
                </StackPanel>
                
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="姓" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox Text="{x:Bind ViewModel.LastName.Value, Mode=TwoWay}"
                             PlaceholderText="例：山田" />
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="名" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox Text="{x:Bind ViewModel.FirstName.Value, Mode=TwoWay}"
                             PlaceholderText="例：太郎" />
                </StackPanel>

                <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Text="情報システムID" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBox Text="{x:Bind ViewModel.UserId.Value, Mode=TwoWay}"
                             PlaceholderText="例：U001" />
                </StackPanel>
            </Grid>

           
       

            <!-- 管理者チェックボックス -->
            <CheckBox Content="管理者として使用する（ファイル変更通知を受け取る&amp;ログ一覧表示）※再起動必須"
                      IsChecked="{x:Bind ViewModel.IsAdmin.Value, Mode=TwoWay}" />

            <!-- ============================= -->
            <!-- 出退勤ログファイルパス          -->
            <!-- ============================= -->
            <TextBlock Text="出退勤ログファイルパス（最大3件）"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,8,0,0" />
            <TextBlock Text="部署を兼務している場合は複数のパスを登録できます。"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <!-- ログパス 1 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="XMLファイルパス" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBox Text="{x:Bind ViewModel.LogFilePaths[0].FilePath.Value, Mode=TwoWay}"
                                 PlaceholderText="例：\\server\share\Log2026.xml" />
                    </StackPanel>
                    <!-- 新規XMLファイル作成ボタン -->
                    <Button Grid.Column="1" VerticalAlignment="Bottom"
                            Click="CreateLogFile0_Click"
                            ToolTipService.ToolTip="新規XMLファイルを作成してパスをセットする">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE8A5;" FontSize="14" />
                            <TextBlock Text="新規作成" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ログパス 2 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="XMLファイルパス" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBox Text="{x:Bind ViewModel.LogFilePaths[1].FilePath.Value, Mode=TwoWay}"
                                 PlaceholderText="（任意）" />
                    </StackPanel>
                    <!-- 新規XMLファイル作成ボタン -->
                    <Button Grid.Column="1" VerticalAlignment="Bottom"
                            Click="CreateLogFile1_Click"
                            ToolTipService.ToolTip="新規XMLファイルを作成してパスをセットする">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE8A5;" FontSize="14" />
                            <TextBlock Text="新規作成" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ログパス 3 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="XMLファイルパス" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBox Text="{x:Bind ViewModel.LogFilePaths[2].FilePath.Value, Mode=TwoWay}"
                                 PlaceholderText="（任意）" />
                    </StackPanel>
                    <!-- 新規XMLファイル作成ボタン -->
                    <Button Grid.Column="1" VerticalAlignment="Bottom"
                            Click="CreateLogFile2_Click"
                            ToolTipService.ToolTip="新規XMLファイルを作成してパスをセットする">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE8A5;" FontSize="14" />
                            <TextBlock Text="新規作成" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- デフォルトログファイル選択 -->
            <StackPanel Spacing="4">
                <TextBlock Text="デフォルトのログファイル（起動時に選択される）"
                           Style="{StaticResource CaptionTextBlockStyle}" />
                <ComboBox SelectedIndex="{x:Bind ViewModel.DefaultLogFileIndex.Value, Mode=TwoWay}"
                          MinWidth="200">
                    <ComboBoxItem Content="パス 1" />
                    <ComboBoxItem Content="パス 2" />
                    <ComboBoxItem Content="パス 3" />
                </ComboBox>
            </StackPanel>

            <!-- ============================= -->
            <!-- 保存ボタン / フォルダを開くボタン -->
            <!-- ============================= -->
            <StackPanel Orientation="Horizontal" Spacing="8">

                <!-- 設定を保存する -->
                <Button Command="{x:Bind ViewModel.SaveCommand}"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74E;" FontSize="14" />
                        <TextBlock Text="保存" />
                    </StackPanel>
                </Button>

                <!-- settings.json の格納フォルダをエクスプローラーで開く -->
                <Button Click="OpenSettingsFolder_Click"
                        ToolTipService.ToolTip="settings.json の保存フォルダをエクスプローラーで開く">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8DA;" FontSize="14" />
                        <TextBlock Text="設定フォルダを開く" />
                    </StackPanel>
                </Button>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
